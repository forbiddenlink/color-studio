{
  "name": "color-studio",
  "version": "1.0.0",
  "description": "A powerful color manipulation tool for designers and developers",
  "scripts": {
    "start": "webpack serve --mode development",
    "watch": "webpack -w --mode development",
    "build": "webpack --mode production",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "culori": "^4.0.2",
    "posthog-js": "^1.396.9",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^5.2.6"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@biomejs/biome": "^2.5.3",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "style-loader": "^4.0.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "license": "MIT",
  "private": false,
  "pnpm": {
    "overrides": {
      "webpack-dev-server": ">=5.2.1",
      "on-headers": ">=1.1.0",
      "qs": ">=6.14.2",
      "webpack": ">=5.104.1",
      "ajv": ">=8.18.0",
      "minimatch": ">=3.1.4",
      "serialize-javascript": ">=7.0.5",
      "path-to-regexp": "0.1.13",
      "vite": ">=8.0.5",
      "protobufjs": "^7.6.1",
      "dompurify": ">=3.4.0",
      "follow-redirects": ">=1.16.0",
      "@babel/plugin-transform-modules-systemjs": ">=7.27.0",
      "uuid": ">=11.1.1",
      "postcss": ">=8.5.10"
    }
  }
}
